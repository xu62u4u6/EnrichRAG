# OpenAI API key (required for LLM analysis)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Tavily API key (required for web search)
TAVILY_API_KEY=tvly-your-tavily-api-key-here

# Email for NCBI Entrez API (required for PubMed queries)
PUBMED_EMAIL=your@email.com

# LLM model to use (default: gpt-4o)
LLM_MODEL=gpt-4o

# Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# Route prefix for reverse proxy (default: "")
URL_PREFIX=""

# Toggle local knowledge graph (default: true)
KG_ENABLED=true

# Invite code for user registration
AUTH_INVITE_CODE=enrichrag-invite

# Set to true when serving over HTTPS in production
AUTH_SECURE_COOKIES=false
